  "devices": [
    "ALL"
  ],
  "trimrate": true,
  "workload": "prep",
  "secure_erase_option": 0,
  "iogo_runtime": 30,
  "fdp_setup": true,
  "flash_config_logging": false,
  "skip_health_check": true,
  "disable_config_collection": true
