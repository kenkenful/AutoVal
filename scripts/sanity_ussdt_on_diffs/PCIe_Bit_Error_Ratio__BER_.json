{
  "drive_interface": "nvme",
  "drives": [
    "nvme0n1"
  ],
  "include_boot_drive": false,
  "only_boot_drive": false,
  "remove_partition": false,
  "unmount_before_test": false,
  "drive_type": "ssd",
  "fio_timeout": 216000,
  "nvme_delay": 250,
  "run_definition": {
    "bit_error_io": {
      "args": {
        "BLK_ALIGN": "128K",
        "BLK_SIZE": "128K",
        "LOOPS": 1,
        "NAME": "ReadWriteSeq",
        "RDWR": "readwrite",
        "RWMIX_READ": 50,
        "RWMIX_WRITE": 50,
        "SIZE": "143750G"
      },
      "template": "bit_error_ratio.fio"
    }
  },
  "runtime": 900,
  "switchtec_delay": 720,
  "collect_drive_data": false,
  "flash_config_logging": false,
  "skip_health_check": true,
  "disable_config_collection": true
}
