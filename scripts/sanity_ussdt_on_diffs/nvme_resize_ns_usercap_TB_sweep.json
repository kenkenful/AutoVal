{
  "drive_type": "ssd",
  "drive_interface": "nvme",
  "drives": [
    "nvme0n1"
  ],
  "include_boot_drive": false,
  "only_boot_drive": false,
  "remove_partition": false,
  "unmount_before_test": false,
  "sweep_param_key": "usercapacity",
  "sweep_param_unit": "num_TB",
  "sweep_param_values": {
    "0": 0.5
  },
  "nvme_id_ctrl_filter": "nvme_id_ctrl[\"tnvmcap\"] >= 536870912000",
  "cycle_count": 1,
  "revert_sweep_param_key": "overprovisioning",
  "revert_sweep_param_unit": "percent",
  "revert_sweep_param_values": {
    "0": 50
  },
  "skip_iops_validation": true,
  "run_definition": {
    "filesystem_io": {
      "template": "filesystem_template.job",
      "args": {
        "NAME": "fio_nvme",
        "RW": "write",
        "BLKSIZE": "4K",
        "SIZE": "10G",
        "RUNTIME": 60,
        "DEPTH": 128,
        "MIXWRITE": 50,
        "MIXREAD": 50
      }
    }
  },
  "collect_drive_data": false,
  "flash_config_logging": false,
  "skip_health_check": true,
  "disable_config_collection": true
}
