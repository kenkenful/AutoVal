{
  "drive_interface": "nvme",
  "drives": [
    "nvme0n1"
  ],
  "include_boot_drive": false,
  "only_boot_drive": false,
  "remove_partition": false,
  "unmount_before_test": false,
  "cycle_type_list": [
    "warm"
  ],
  "percent_write_size": 10,
  "write_fio": {
    "ssd_md5": {
      "template": "basic_write.fio",
      "args": {
        "NAME": "fio_raw_test",
        "BLKSIZE": "128k",
        "SIZE": "6G",
        "DEPTH": 128,
        "RUNTIME": "5m",
        "VERIFY": "md5",
        "RW": "randwrite"
      }
    }
  },
  "read_fio": {
    "ssd_md5": {
      "template": "basic_read.fio",
      "args": {
        "NAME": "fio_raw_test",
        "BLKSIZE": "128k",
        "SIZE": "6G",
        "DEPTH": 128,
        "RUNTIME": "5m",
        "VERIFY": "md5",
        "RW": "randread"
      }
    }
  },
  "verify_fio": {
    "ssd_md5": {
      "template": "basic_verify.fio",
      "args": {
        "NAME": "fio_raw_test",
        "BLKSIZE": "128k",
        "SIZE": "6G",
        "DEPTH": 128,
        "RW": "randread",
        "VERIFY": "md5"
      }
    }
  },
  "collect_drive_data": false,
  "flash_config_logging": false,
  "skip_health_check": true,
  "disable_config_collection": true
}
