{
    "skip_iops_validation": true,
    "skip_clean_filesystem": true,
    "remove_partition": false,
    "test_generic_drives": true,
    "t10_dix_format": true,
    "qlc_perf_test": true,
    "workload_type": "qlc_performance",
    "enable_performance_metrics_validation": true,
    "clat_percentiles": ["99.000000", "99.990000", "99.999000", "99.999900"],
    "run_definition": {
        "randrw": {
            "template": "qlc_performance.fio",
            "args": {
                "BLOCKSIZE": ["32K,1M","128K,1M","32K,128k","128K,128k"],
                "IODEPTH":[4, 8, 16, 32, 64, 128, 256, 512],
                "SIZE": "100%",
                "NUMJOBS": "1",
                "OFFSET": "0",
                "RUNTIME": "10m",
                "RWMIXREAD": "80"
            }
        }
    }
}
