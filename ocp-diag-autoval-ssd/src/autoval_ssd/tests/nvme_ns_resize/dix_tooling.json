{
    "drive_type": "ssd",
    "drive_interface": "nvme",
    "sweep_param_key": "overprovisioning",
    "sweep_param_unit": "percent",
    "sweep_param_values": [75],
    "cycle_count": 1,
    "dix_ns_resize": true,
    "validate_tooling": true,
    "skip_iops_validation": true,
    "run_definition": {
      "filesystem_io": {
        "template": "filesystem_template.job",
        "args": {
            "NAME": "fio_nvme",
            "RW": "write",
            "SIZE": "10G",
            "RUNTIME": 60,
            "DEPTH": 128,
            "MIXWRITE": 50,
            "MIXREAD": 50
        }
      }
    }
  }
