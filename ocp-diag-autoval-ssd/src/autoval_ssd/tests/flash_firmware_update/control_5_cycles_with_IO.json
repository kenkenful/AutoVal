{
		"drive_type": "ssd",
    "include_boot_drive": true,
    "cycle": 5,
    "versions": ["latest", "stable"],
    "verify_io": true,
    "run_definition": {
      "random_read_write": {
        "template": "range_verify.job",
        "args": {
            "RW": "randrw",
            "BLKSIZERANGE": "4k-128k",
            "SIZE": "10G",
            "RUNTIME": "5m",
            "DEPTH": 128,
            "VERIFY": "crc32c"
        }
      }
    }
}
